PORT=4000
NODE_ENV=development

# Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/enjay_helpdesk?schema=public"

# JWT Auth Foundation
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# Security & CORS (Required for production)
FRONTEND_URL="http://localhost:5173"

# AI Configuration
AI_PROVIDER=gemini
GEMINI_API_KEY=

# Logging
LOG_LEVEL=info
