generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
//                 ENUMS
// ==========================================

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFICATION_COMPLETED
  ACCOUNT_CREATED
  ACCOUNT_UPDATED
  ACCOUNT_DELETED
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  ON_HOLD
  RESOLVED
  CLOSED
  REOPENED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum TicketSource {
  WEB
  EMAIL
  PHONE
  CHAT
  API
}

enum TicketType {
  INCIDENT
  SERVICE_REQUEST
  BUG
  FEATURE_REQUEST
  QUESTION
}

enum TicketCategory {
  SOFTWARE
  HARDWARE
  NETWORK
  ACCOUNT
  EMAIL
  SECURITY
  OTHER
}

// ==========================================
//               AUTH / USERS
// ==========================================

model Role {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?

  users       User[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("roles")
}

model User {
  id                         String    @id @default(uuid())
  email                      String    @unique
  passwordHash               String
  fullName                   String?
  avatar                     String?
  phone                      String?

  roleId                     String
  role                       Role      @relation(fields: [roleId], references: [id])

  isActive                   Boolean   @default(true)
  deletedAt                  DateTime?

  isEmailVerified            Boolean   @default(false)
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?

  passwordResetToken         String?   @unique
  passwordResetExpiresAt     DateTime?

  lastLoginAt                DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  refreshTokens              RefreshToken[]
  auditLogs                  AuditLog[]

  // Ticket Engine Relations
  requestedTickets           Ticket[]         @relation("RequestedTickets")
  assignedTickets            Ticket[]         @relation("AssignedTickets")
  comments                   TicketComment[]
  activities                 TicketActivity[]
  watching                   TicketWatcher[]
  uploadedAttachments        Attachment[]

  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id              String    @id @default(uuid())
  token           String    @unique

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceName      String?
  ipAddress       String?

  expiresAt       DateTime
  revokedAt       DateTime?
  replacedByToken String?   @unique

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction

  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  ipAddress   String?
  userAgent   String?
  details     Json?

  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ==========================================
//              TICKET ENGINE
// ==========================================

// Atomic sequence generator for concurrency-safe human-readable ticket numbers
model TicketSequence {
  id        String   @id @default("TICKET_SEQ")
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("ticket_sequences")
}

model Ticket {
  id                  String         @id @default(uuid())
  // Generated using TicketSequence: e.g. HD-2026-000001
  ticketNumber        String         @unique

  title               String
  description         String         @db.Text

  status              TicketStatus   @default(NEW)
  priority            TicketPriority @default(MEDIUM)
  source              TicketSource   @default(WEB)
  type                TicketType     @default(QUESTION)
  category            TicketCategory @default(OTHER)

  // Optimistic Locking to prevent concurrent update anomalies
  version             Int            @default(1)

  // Relationships
  requesterId         String
  requester           User           @relation("RequestedTickets", fields: [requesterId], references: [id])

  assigneeId          String?
  assignee            User?          @relation("AssignedTickets", fields: [assigneeId], references: [id])

  // SLAs & Timestamps
  firstResponseAt     DateTime?
  firstResponseDueAt  DateTime?
  resolvedAt          DateTime?
  resolutionDueAt     DateTime?
  closedAt            DateTime?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  // AI Context
  aiSummary           String?        @db.Text
  aiSentiment         String?
  aiPriority          TicketPriority?
  aiConfidence        Float?
  aiCategoryReason    String?        @db.Text
  duplicateScore      Float?

  // Sub-modules
  comments            TicketComment[]
  activities          TicketActivity[]
  watchers            TicketWatcher[]
  attachments         Attachment[]
  tags                TicketTag[]

  // Indexes for high-performance dashboard filtering
  @@index([ticketNumber])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([requesterId])
  @@index([assigneeId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("tickets")
}

model TicketComment {
  id          String       @id @default(uuid())
  content     String       @db.Text
  isInternal  Boolean      @default(false)

  ticketId    String
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId    String
  author      User         @relation(fields: [authorId], references: [id])

  attachments Attachment[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  editedAt    DateTime?
  deletedAt   DateTime?

  @@index([ticketId])
  @@map("ticket_comments")
}

model TicketActivity {
  id          String    @id @default(uuid())
  action      String

  previous    Json?
  current     Json?

  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  actorId     String
  actor       User      @relation(fields: [actorId], references: [id])

  // Security & Audit Context
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime  @default(now())

  @@index([ticketId])
  @@map("ticket_activities")
}

model TicketWatcher {
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@id([ticketId, userId])
  @@map("ticket_watchers")
}

model Tag {
  id          String      @id @default(uuid())
  name        String      @unique
  color       String?
  tickets     TicketTag[]

  @@map("tags")
}

model TicketTag {
  ticketId    String
  ticket      Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  tagId       String
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@map("ticket_tags")
}

model Attachment {
  id            String         @id @default(uuid())
  fileName      String
  fileSize      Int
  mimeType      String
  url           String

  // Security & Verification
  checksum      String?
  virusScanned  Boolean        @default(false)

  ticketId      String?
  ticket        Ticket?        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  commentId     String?
  comment       TicketComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  uploadedById  String
  uploadedBy    User           @relation(fields: [uploadedById], references: [id])

  createdAt     DateTime       @default(now())
  deletedAt     DateTime?

  @@index([ticketId])
  @@index([commentId])
  @@map("attachments")
}